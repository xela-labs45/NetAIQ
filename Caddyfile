{
	# Force Caddy to use the IP certificate when the client doesn't send SNI
	# (which happens when connecting via IP address)
	default_sni {$SITE_ADDRESS}
}

{$SITE_ADDRESS}, localhost, 127.0.0.1 {
	# Caddy automatically uses internal SSL for these local addresses.
	# For public domains, it will automatically use Let's Encrypt.
	tls internal
	reverse_proxy netmon:3001
}
