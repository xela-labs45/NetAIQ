# ─────────────────────────────────────────────
# NetAIQ Environment Variables
# ─────────────────────────────────────────────
# Only core boot-time values live here.
# UniFi, SMTP, and all other settings are 
# configured through the Settings page in the UI
# and stored in the database.
# ─────────────────────────────────────────────

PORT=3001
NODE_ENV=production
JWT_SECRET=replace_with_a_random_64_character_string
DB_PATH=./data/netaiq.db

# SSL / Proxy Settings
# Use your domain (e.g. netaiq.example.com) for public SSL
# Use 'localhost' or your local IP for local-only SSL (Caddy internal CA)
SITE_ADDRESS=localhost
HTTP_PORT=3080
HTTPS_PORT=3443
