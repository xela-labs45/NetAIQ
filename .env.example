# ─────────────────────────────────────────────────────────────────────────────
# NetAIQ Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values before starting the stack.
# UniFi, SMTP, Telegram, and AI settings are configured through the Settings
# page in the UI and stored in the database — they do not belong here.
# ─────────────────────────────────────────────────────────────────────────────

# Port the Node app listens on inside the container.
# With the default docker-compose.yml this is also the host port.
PORT=3001

NODE_ENV=production

# Generate a strong random secret (at least 64 characters).
# Example: openssl rand -hex 64
JWT_SECRET=replace_with_a_random_64_character_string

DB_PATH=./data/netaiq.db

# ── Caddy HTTPS overlay only ──────────────────────────────────────────────────
# The variables below are only used when running the Caddy overlay:
#   docker compose -f docker-compose.yml -f docker-compose.caddy.yml up -d
#
# SITE_ADDRESS — set to your LAN IP or public domain.
#   localhost / LAN IP  → Caddy internal CA (self-signed cert, browser warning)
#   public domain       → Let's Encrypt (trusted, requires ports 80/443 open)
#
# For Let's Encrypt, set HTTP_PORT=80 and HTTPS_PORT=443 (or forward your
# router's 80/443 to these ports).
# ─────────────────────────────────────────────────────────────────────────────
SITE_ADDRESS=localhost
HTTP_PORT=3080
HTTPS_PORT=3443
